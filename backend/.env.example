# Copy to .env and fill in real values
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=change-me-to-a-long-random-string
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=https://munister-v.github.io
# Google Sign-In — OAuth 2.0 Web client ID from Google Cloud Console.
# Leave empty to disable the "Continue with Google" button.
GOOGLE_CLIENT_ID=
# Secret guarding /api/auth/make-admin and /set-role. Leave unset to disable them.
ADMIN_SECRET=

# ── AI engine (Teacher Tools) ───────────────────────────────────────────────
# Free OpenAI-compatible LLM for /api/ai/teacher-tool. Leave AI_API_KEY empty to
# keep the offline rule-engine fallback. Get a free key from Groq or Gemini.
#   Groq    : AI_BASE_URL=https://api.groq.com/openai/v1                          AI_MODEL=llama-3.3-70b-versatile
#   Gemini  : AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai AI_MODEL=gemini-2.0-flash
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1                          AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
# AI_TIMEOUT_MS=25000
# Optional duplicate/fallback provider — tried automatically when the primary
# rate-limits or errors, before degrading to the local rule engine.
# Default base/model target OpenRouter's free tier.
AI_API_KEY_2=
AI_BASE_URL_2=https://openrouter.ai/api/v1
AI_MODEL_2=meta-llama/llama-3.3-70b-instruct:free
# Native OpenRouter fallback chain. When AI_BASE_URL or AI_BASE_URL_2 points to
# OpenRouter, the backend sends this list as `models` so OpenRouter can fail over
# across models/providers before the app falls back to local templates.
AI_OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-72b-instruct:free,deepseek/deepseek-chat:free
# Prefer speed across available OpenRouter endpoints/models. Valid: throughput,
# latency, price. Default is throughput.
# AI_OPENROUTER_SORT=throughput
# Enable OpenRouter response-healing plugin for JSON repair. Set 0 to disable.
# AI_OPENROUTER_RESPONSE_HEALING=1
# Attempts per provider before moving to the next local provider.
# AI_MAX_ATTEMPTS=2
